license: Apache-2.0
date-released: "2026-04-29"
version: "0.2"
keywords:
  - ensemble divergence
  - structural opacity
  - AI auditing
  - implicit contracts
  - orphaned invariants
  - composition seams
  - software engineering
  - AI execution frameworks
  - reproducibility
  - methods underspecification

